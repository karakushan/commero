{
    "name": "karakushan/commero",
    "description": "Laravel ecommerce, CMS, and admin core package extracted from the Shophats project.",
    "type": "library",
    "license": "proprietary",
    "require": {
        "php": "^8.3",
        "filament/filament": "^5.0",
        "laravel/framework": "^13.0",
        "spatie/laravel-permission": "^7.3"
    },
    "autoload": {
        "psr-4": {
            "Commero\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Commero\\Providers\\CommeroServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
